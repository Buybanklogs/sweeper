{
  "name": "evm-walletconnect-backend",
  "version": "1.0.0",
  "description": "Consent-first EVM WalletConnect backend for multi-chain wallet synchronization.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
